{% extends "layout.mjml" %}

{% block title %}
<mj-title>{{ t('emails.validateInstitution.title') }}</mj-title>
{% endblock %}

{% block content %}

<mj-section>
  <mj-column>
    <mj-text mj-class="headline">{{ t('emails.validateInstitution.body.headline') }}</mj-text>
  </mj-column>
</mj-section>

<mj-section>
  <mj-column>

    <mj-text>
      <p>{{ t('emails.validateInstitution.body.p1') }}</p>
      <p>
        {{ t('emails.validateInstitution.body.p2', { manageMemberLink: (manageMemberLink | e), manageSushiLink: (manageSushiLink | e) }) | safe }}
      </p>
    </mj-text>

    <mj-text>
      <p>{{ t('emails.global.regards') }}</p>
      <p>{{ t('emails.global.theTeam') }}</p>
    </mj-text>
  </mj-column>
</mj-section>

{% endblock %}
