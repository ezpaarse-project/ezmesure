{% extends "layout.mjml" %}

{% block title %}
<mj-title>{{ t('emails.errorHappened.title') }}</mj-title>
{% endblock %}

{% block content %}

<mj-section>
  <mj-column>
    <mj-text mj-class="headline">{{ t('emails.errorHappened.body.headline') }}</mj-text>
  </mj-column>
</mj-section>

<mj-section>
  <mj-column>
    <mj-text>{{ message }}</mj-text>
    <mj-text>
      <strong>{{ error }}</strong>
    </mj-text>
  </mj-column>
</mj-section>

{% endblock %}
